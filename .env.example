# === Локальный запуск: заполни .env. На Railway эти же ключи задаются как Variables ===

# Токен от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# ID Google-таблицы (из её URL: docs.google.com/spreadsheets/d/<ВОТ_ЭТО>/edit)
GSHEET_ID=

# --- доступ к Google: один из двух способов ---
# (локально) путь к файлу ключа сервисного аккаунта:
GOOGLE_CREDENTIALS_FILE=credentials.json
# (на Railway) вместо файла — весь JSON ключа одной переменной:
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ... }

# Файл базы. Локально — vocab.db. На Railway укажи путь на Volume:
DB_PATH=vocab.db
# DB_PATH=/data/vocab.db

# Часовой пояс и окно напоминаний (каждый час включительно)
TZ=Europe/Madrid
REMINDER_START=10
REMINDER_END=18

# Сколько новых слов вводить за день
DAILY_NEW=10
SUBBATCH=5
PASSES=3

# На Railway при подключённом Volume также добавь переменную:
# RAILWAY_RUN_UID=0
